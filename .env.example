# ─── News ────────────────────────────────────────────────────────────────────
# Al Jazeera RSS is used directly — no API key needed!


# ─── LLM ─────────────────────────────────────────────────────────────────────
# Get a free key at https://aistudio.google.com  (1500 req/day free)
GEMINI_API_KEY=your_gemini_api_key_here

# ─── Instagram ────────────────────────────────────────────────────────────────
# Choose publishing method: "graph_api" or "instagrapi"
INSTAGRAM_PUBLISH_METHOD=instagrapi

# --- Option A: instagrapi (easier, works with personal/creator accounts) ------
INSTAGRAM_USERNAME=your_instagram_username
INSTAGRAM_PASSWORD=your_instagram_password

# --- Option B: Graph API (official, requires Business account + Facebook App) -
# Full setup guide: see README.md → "Instagram Graph API Setup"
IG_USER_ID=your_instagram_user_id
IG_ACCESS_TOKEN=your_long_lived_access_token

# ─── Scheduler ───────────────────────────────────────────────────────────────
# How often to post (in hours)
POST_INTERVAL_HOURS=6
